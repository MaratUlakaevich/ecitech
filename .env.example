# ============================================================
# ECITech — .env.example
# Copy to .env.local and fill in real values. Never commit .env.local.
# ============================================================

# --- Strapi CMS (blog) ---
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_API_TOKEN=your_strapi_read_token_here
NEXT_PUBLIC_PAGE_LIMIT=6

# --- Email (Resend) ---
# Get key at https://resend.com/api-keys
# Verify domain ecitech.online (SPF/DKIM/DMARC) before going live.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# From address on verified domain
RESEND_FROM_EMAIL=no-reply@ecitech.online
# Primary lead inbox
LEAD_NOTIFICATION_EMAIL=ulakaev@ecitech.online
# Backup CC so a single inbox is not a SPOF
LEAD_NOTIFICATION_CC=info@ecitech.online

# --- Notion CRM ---
# Create integration at https://www.notion.so/my-integrations
# Share target databases with the integration.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_LEADS_DB_ID=
NOTION_COMPANIES_DB_ID=
NOTION_CONVERSATIONS_DB_ID=

# --- Supabase (scaffolding; create project before week 2 AI agent work) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx
# Server-side only — NEVER expose
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxx

# --- Cloudflare Turnstile (form anti-bot) ---
# Create site at https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_site_key
TURNSTILE_SECRET_KEY=0x4AAAAAAA_secret_key

# --- Upstash Redis (rate limit) ---
# https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-region-xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AYourTokenHere

# --- Telegram (lead alerts) ---
# Create bot via @BotFather, add it to target chat, get chat id via @userinfobot or getUpdates.
TELEGRAM_BOT_TOKEN=123456789:AA_your_bot_token
TELEGRAM_CHAT_ID=-1001234567890

# --- Cal.com (discovery-call embed) ---
NEXT_PUBLIC_CALCOM_LINK=ecitech/30min

# --- Site base URL ---
NEXT_PUBLIC_SITE_URL=https://ecitech.online
